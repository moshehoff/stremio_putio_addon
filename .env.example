# העתק ל-.env ומלא ערכים. קובץ זה בטוח ל-Git (בלי secrets אמיתיים).

PUTIO_TOKEN=
PUTIO_CLIENT_ID=
PUTIO_CLIENT_SECRET=

TMDB_API_KEY=

BASE_URL=http://127.0.0.1:7000
PORT=7000
# Check http://127.0.0.1:7000/health for install URLs
# Android HTTPS tunnel — optional, auto-detected from Downloads if unset
# CLOUDFLARED_PATH=C:\Users\YOU\Downloads\cloudflared-windows-amd64.exe
# Random string for signing proxy URLs (e.g. openssl rand -hex 32)
SECRET_KEY=

DATABASE_URL=postgresql://app:dev@localhost:5432/putio_stremio
REDIS_URL=redis://localhost:6379

LOG_LEVEL=info
NODE_ENV=development
